---
import "../styles/global.css";

interface Props {
  title: string;
}

const { title } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <script is:inline>
      if (
        localStorage.getItem("theme") === "dark" ||
        (!localStorage.getItem("theme") &&
          window.matchMedia("(prefers-color-scheme: dark)").matches)
      ) {
        document.documentElement.classList.add("dark");
      }
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Nav -->
    <nav
      class="sticky top-0 z-50 border-b"
      style="background: rgba(255,255,255,0.8); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border-color: var(--color-border);"
    >
      <div class="mx-auto flex max-w-2xl items-center justify-between px-6 h-14">
        <!-- Left: Wordmark -->
        <a
          href="/"
          class="text-base font-semibold tracking-tight no-underline"
          style="color: var(--color-primary); letter-spacing: -0.02em;"
        >
          Julian Ouyang
        </a>

        <!-- Right: Nav links + toggle + sign in -->
        <div class="flex items-center gap-1">
          <a
            href="/"
            class={`px-3 py-1.5 text-sm font-medium rounded-md no-underline transition-colors ${currentPath === "/" ? "" : ""}`}
            style={currentPath === "/"
              ? `color: var(--color-accent);`
              : `color: var(--color-muted);`}
          >
            Writing
          </a>
          <a
            href="/about"
            class="px-3 py-1.5 text-sm font-medium rounded-md no-underline transition-colors"
            style={currentPath === "/about"
              ? `color: var(--color-accent);`
              : `color: var(--color-muted);`}
          >
            About
          </a>

          <div class="w-px h-4 mx-2" style="background: var(--color-border);"></div>

          <!-- Dark mode toggle -->
          <button
            id="theme-toggle"
            type="button"
            class="rounded-full p-2 transition-colors hover:opacity-70"
            style="color: var(--color-muted);"
            aria-label="Toggle dark mode"
          >
            <svg
              id="sun-icon"
              class="hidden h-4 w-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"
              ></path>
            </svg>
            <svg
              id="moon-icon"
              class="hidden h-4 w-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"
              ></path>
            </svg>
          </button>

          <!-- Sign In -->
          <a
            id="nav-sign-in"
            href="/login"
            class="ml-1 rounded-lg px-3 py-1.5 text-sm font-medium no-underline transition-colors"
            style="color: var(--color-accent);"
          >
            Sign In
          </a>
        </div>
      </div>
    </nav>

    <!-- Dark mode nav background override -->
    <style is:inline>
      html.dark nav.sticky {
        background: rgba(15, 23, 42, 0.8) !important;
      }
    </style>

    <!-- Main -->
    <main class="mx-auto w-full max-w-2xl flex-1 px-6 pt-10 pb-16">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t" style="border-color: var(--color-border);">
      <div class="mx-auto flex max-w-2xl flex-col items-center justify-between gap-3 px-6 py-8 text-xs sm:flex-row" style="color: var(--color-muted);">
        <span>&copy; 2026 Julian Ouyang</span>
        <span>junliangouyang.com</span>
        <a
          href="https://github.com/Julianouyang"
          target="_blank"
          rel="noopener noreferrer"
          class="no-underline transition-colors hover:opacity-70"
          style="color: var(--color-muted);"
        >
          GitHub
        </a>
      </div>
    </footer>

    <script is:inline>
      (function () {
        const toggle = document.getElementById("theme-toggle");
        const sunIcon = document.getElementById("sun-icon");
        const moonIcon = document.getElementById("moon-icon");

        function updateIcons() {
          const isDark =
            document.documentElement.classList.contains("dark");
          sunIcon.classList.toggle("hidden", !isDark);
          moonIcon.classList.toggle("hidden", isDark);
        }

        updateIcons();

        toggle.addEventListener("click", () => {
          document.documentElement.classList.toggle("dark");
          const isDark =
            document.documentElement.classList.contains("dark");
          localStorage.setItem("theme", isDark ? "dark" : "light");
          updateIcons();
        });

        // Hide sign-in button if user is already logged in (firebase token in localStorage)
        try {
          const keys = Object.keys(localStorage);
          const hasFirebaseUser = keys.some(k => k.startsWith("firebase:authUser:"));
          if (hasFirebaseUser) {
            const signInBtn = document.getElementById("nav-sign-in");
            if (signInBtn) signInBtn.style.display = "none";
          }
        } catch (e) {}
      })();
    </script>
  </body>
</html>
