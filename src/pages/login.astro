---
import BaseLayout from "../layouts/BaseLayout.astro";
import AuthGate from "../components/AuthGate";
---

<BaseLayout title="Sign In — Julian Ouyang">
  <div class="flex flex-col items-center justify-center py-20 md:py-28">
    <div class="w-full max-w-sm text-center">
      <div
        class="mx-auto mb-8 flex h-12 w-12 items-center justify-center rounded-full"
        style="background: var(--color-tag-bg);"
      >
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-muted);">
          <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
          <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
        </svg>
      </div>

      <h1 class="text-2xl font-bold tracking-tight" style="letter-spacing: -0.02em;">
        Sign In
      </h1>
      <p class="mt-2 text-sm" style="color: var(--color-muted);">
        Access private content
      </p>

      <div class="mt-10">
        <AuthGate client:only="react">
          <div class="text-center">
            <div
              class="mx-auto mb-4 flex h-10 w-10 items-center justify-center rounded-full"
              style="background: #22c55e20; color: #22c55e;"
            >
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <p class="text-sm font-medium" style="color: var(--color-muted);">
              You're signed in.
            </p>
            <a
              href="/"
              class="mt-4 inline-block text-sm font-medium"
            >
              Go to writing &rarr;
            </a>
          </div>
        </AuthGate>
      </div>
    </div>
  </div>
</BaseLayout>
